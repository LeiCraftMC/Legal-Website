# Prevent Apache from forcing the trailing slash
DirectorySlash Off
RewriteEngine On
RewriteBase /

# 1. Remove trailing slashes (External Redirect)
# Only redirect if it's not an actual directory that needs the slash for some reason
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} ^(.+)/$
RewriteRule ^(.+)/$ /$1 [R=301,L]

# 2. Remove index.html from the URL (External Redirect)
RewriteRule ^index\.html$ / [R=301,L]
RewriteRule ^(.*)/index\.html$ /$1 [R=301,L]

# 3. Internal Mapping (The "Nitro" magic)
# If the request is for /site, check if /site/index.html exists and serve it quietly
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_FILENAME}/index.html -f
RewriteRule ^(.*)$ $1/index.html [L]

ErrorDocument 404 /404.html